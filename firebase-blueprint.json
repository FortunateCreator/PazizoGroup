{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing role and basic information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "fullName": { "type": "string", "description": "User's full name." },
        "role": { 
          "type": "string", 
          "enum": ["admin", "client", "content_marketing", "logistics_partner"],
          "description": "The role assigned to the user for RBAC."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Delivery Order",
      "description": "An order for fuel delivery.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID." },
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "fullName": { "type": "string", "description": "Name of the customer." },
        "email": { "type": "string", "format": "email", "description": "Customer email." },
        "phone": { "type": "string", "description": "Customer phone number." },
        "volume": { "type": "number", "description": "Volume of fuel in liters." },
        "status": { 
          "type": "string", 
          "enum": ["pending", "in-transit", "delivered"],
          "description": "Current status of the order."
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed." }
      },
      "required": ["userId", "fullName", "email", "volume", "status", "location", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of delivery orders."
    }
  }
}
